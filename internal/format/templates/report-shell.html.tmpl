<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{.Title}}</title>
<style>
  :root {
    --bg: #0d1117;
    --surface: #161b22;
    --border: #30363d;
    --text: #e6edf3;
    --text-muted: #8b949e;
    --accent: #58a6ff;
    --yellow: #d29922;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    padding: 2rem;
    max-width: 960px;
    margin: 0 auto;
  }
  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }
  h1 { font-size: 1.5rem; margin: 1.5rem 0 0.5rem; }
  h2 { font-size: 1.3rem; margin: 1.5rem 0 0.75rem; color: var(--accent); border-bottom: 1px solid var(--border); padding-bottom: 0.3rem; }
  h3 { font-size: 1.1rem; margin: 1.2rem 0 0.5rem; }
  h4 { font-size: 1rem; margin: 1rem 0 0.4rem; color: var(--text-muted); }
  p { margin: 0.5rem 0; }
  ul, ol { margin: 0.25rem 0 0.75rem 1.5rem; }
  li { margin: 0.15rem 0; }
  table {
    width: 100%;
    border-collapse: collapse;
    margin: 0.75rem 0;
    background: var(--surface);
    border-radius: 6px;
    overflow: hidden;
  }
  th, td {
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
    font-size: 0.9rem;
  }
  th {
    font-weight: 600;
    color: var(--text-muted);
    font-size: 0.8rem;
  }
  tr:last-child td { border-bottom: none; }
  td { font-variant-numeric: tabular-nums; }
  blockquote {
    border-left: 3px solid var(--yellow);
    padding: 0.5rem 1rem;
    margin: 0.75rem 0;
    color: var(--yellow);
    background: rgba(210, 153, 34, 0.08);
    border-radius: 0 4px 4px 0;
  }
  details {
    margin: 0.75rem 0;
    background: var(--surface);
    border-radius: 6px;
    border: 1px solid var(--border);
  }
  summary {
    padding: 0.6rem 0.75rem;
    cursor: pointer;
    font-weight: 600;
    font-size: 0.9rem;
  }
  details table { margin: 0; border-radius: 0; }
  code {
    background: var(--surface);
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    font-size: 0.85em;
  }
  strong { color: var(--text); }
  hr { border: none; border-top: 1px solid var(--border); margin: 1.5rem 0; }
  footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    font-size: 0.8rem;
    color: var(--text-muted);
  }
</style>
</head>
<body>
{{.Content}}
<footer>
  Generated by <a href="https://dvhthomas.github.io/gh-velocity/">gh-velocity</a>
</footer>
</body>
</html>
